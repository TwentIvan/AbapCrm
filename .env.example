# ── Core Authentication ─────────────────────────────────────────────────────────

# OpenAI API key — required for direct OpenAI calls (when AI_GATEWAY_BASE_URL is not set)
OPENAI_API_KEY=sk-...

# ── AI Gateway (optional) ────────────────────────────────────────────────────────

# When set, ALL AI calls are routed through this OpenAI-compatible base URL.
# Useful for LiteLLM, OpenRouter, or any other proxy that exposes the OpenAI API.
# If not set, only "openai/*" model keys work (using OPENAI_API_KEY directly).
# Example: http://localhost:4000   or   https://openrouter.ai/api/v1
AI_GATEWAY_BASE_URL=

# API key sent to the gateway. Defaults to OPENAI_API_KEY if not set.
AI_GATEWAY_API_KEY=

# Default model key to use when no org-level override is configured.
# Must match a model_key in the ai_models table (e.g. openai/gpt-5, anthropic/claude-3-5-sonnet).
# Fallback when not set: "openai/gpt-5"
AI_DEFAULT_MODEL_KEY=openai/gpt-5

# ── Database ─────────────────────────────────────────────────────────────────────

DATABASE_URL=postgresql://...

# ── Session ──────────────────────────────────────────────────────────────────────

SESSION_SECRET=change-me
